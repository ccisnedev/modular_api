{
  "name": "@macss/modular-api",
  "version": "0.6.1",
  "description": "Use-case-centric toolkit for building modular APIs with Express. Define UseCase classes (input → validate → execute → output), connect them to HTTP routes, and expose Swagger/OpenAPI documentation automatically.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dto": {
      "types": "./dist/dto.d.ts",
      "default": "./dist/dto.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "api",
    "usecase",
    "openapi",
    "express",
    "modular"
  ],
  "author": "ccisne.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccisnedev/modular_api.git",
    "directory": "code/ts/modular_api"
  },
  "bugs": {
    "url": "https://github.com/ccisnedev/modular_api/issues"
  },
  "homepage": "https://github.com/ccisnedev/modular_api/tree/main/code/ts/modular_api#readme",
  "dependencies": {
    "express": "^4.22.1",
    "graphql": "^16.11.0",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.11",
    "@types/supertest": "^6.0.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
